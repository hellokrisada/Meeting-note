{
  "name": "flight-search-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "dev:proxy": "concurrently \"npm run server\" \"npm run client\" \"npm run proxy\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "proxy": "node proxy-server.js",
    "install-all": "npm install && cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm install && npm run build",
    "start": "cd server && npm install && node server.js"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "concurrently": "^8.2.2",
    "fast-check": "^4.6.0",
    "http-proxy-middleware": "^2.0.6",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.0"
  },
  "description": "ระบบบันทึกรายงานการประชุมพร้อม AI สรุปการประชุม และส่งสรุปทางอีเมลอัตโนมัติ บน AWS Serverless Architecture",
  "main": "proxy-server.js",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1020.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1020.0",
    "@aws-sdk/client-dynamodb": "^3.1020.0",
    "@aws-sdk/client-ses": "^3.1020.0",
    "@aws-sdk/lib-dynamodb": "^3.1020.0",
    "@types/uuid": "^10.0.0",
    "ansi-regex": "^5.0.1",
    "ansi-styles": "^4.3.0",
    "chalk": "^4.1.2",
    "cliui": "^8.0.1",
    "color-convert": "^2.0.1",
    "color-name": "^1.1.4",
    "date-fns": "^2.30.0",
    "emoji-regex": "^8.0.0",
    "escalade": "^3.2.0",
    "get-caller-file": "^2.0.5",
    "has-flag": "^4.0.0",
    "is-fullwidth-code-point": "^3.0.0",
    "lodash": "^4.17.23",
    "require-directory": "^2.1.1",
    "rxjs": "^7.8.2",
    "shell-quote": "^1.8.3",
    "spawn-command": "^0.0.2",
    "string-width": "^4.2.3",

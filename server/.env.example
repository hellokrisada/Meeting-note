# Server Configuration
JWT_SECRET=your-secret-key-here
PORT=8080
DB_PATH=./data/flights.db

# Flight Search API Configuration
# Choose one: serpapi, amadeus, or mock
FLIGHT_API_PROVIDER=mock

# SerpAPI (Google Flights Scraper)
# Get your API key from: https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# Amadeus API (Alternative)
# Get your API credentials from: https://developers.amadeus.com/
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
